"""Native DLL directories baked at CMake configure time.

This file is generated by `configure_file()` in CMakeLists.txt. The values
are absolute paths on the machine that built the extension; they are used
by `chess_mcts/__init__.py` to register directories with
`os.add_dll_directory` on Windows so LibTorch / TensorRT DLLs resolve
without relying on %PATH% or the CWD.
"""

LIBTORCH_LIB = r"@CHESS_MCTS_LIBTORCH_LIB@"
TENSORRT_BIN = r"@CHESS_MCTS_TENSORRT_BIN@"
